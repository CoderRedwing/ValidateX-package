{
  "name": "validatex-0.1",
  "version": "1.1.0",
  "description": "A lightweight and flexible validation library for JavaScript and TypeScript. Supports email (with typo suggestions), password, username, phone, URL, credit card (with card type detection), date, postal code, IP address, and batch validation.",
  "main": "dist/cjs/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.cjs.json",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts",
    "prepublishOnly": "npm run build",
    "size": "size-limit"
  },
  "sideEffects": false,
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "30 KB"
    }
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "validation",
    "email",
    "password",
    "phone",
    "url",
    "username",
    "form-validation",
    "typescript",
    "credit-card",
    "luhn",
    "ip-address",
    "postal-code",
    "date-validation",
    "batch-validation",
    "nodejs",
    "javascript"
  ],
  "author": "Ajitesh Mishra",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CoderRedwing/ValidateX-package.git"
  },
  "bugs": {
    "url": "https://github.com/CoderRedwing/ValidateX-package/issues"
  },
  "homepage": "https://github.com/CoderRedwing/ValidateX-package#readme",
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.2.0",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "libphonenumber-js": "^1.12.5",
    "size-limit": "^11.2.0"
  },
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/index.d.ts"
    }
  }
}
